  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=44><b><color=#F26B0FFF>WHAT IS B-TIER HOOPS?</color></b></size>\n<size=30>Climb
    the basketball tiers from F (easiest) to S (hardest). Each opponent is a unique
    character with their own stats and AI. Beat them to unlock the next tier.</size>\n\n<size=44><b><color=#F26B0FFF>RULES</color></b></size>\n<size=30>\u2022
    First to 11 points wins\n\u2022 1 minute matches; tied games go to sudden death
    (next score wins)\n\u2022 Shots from your own half count for 3 points; closer
    shots = 2\n\u2022 Slam dunks count for 2 points</size>\n\n<size=44><b><color=#F26B0FFF>CONTROLS</color></b></size>\n<size=30>\u2022
    <b>WASD / Arrows</b> \u2014 Move\n\u2022 <b>Space / W</b> \u2014 Jump\n\u2022
    <b>F</b> \u2014 Hold to charge a shot, release to shoot\n\u2022 <b>Q</b> \u2014
    Steal the ball (your arm must touch the opponent)\n\u2022 <b>R</b> \u2014 Restart
    the current match (after it ends)</size>\n\n<size=26><i>Tip: higher tiers have
    better stats AND smarter AI. Your name shows up everywhere \u2014 including above
    your head in-game.</i></size>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
